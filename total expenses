import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
	   Scanner sc = new Scanner(System.in);
	   int T = sc.nextInt();
	   
	   while(T-->0){
	        int q = sc.nextInt();
	         int p = sc.nextInt();
	         double total = 0;
	         total = q*p;
	       if(q>1000){
	           total = total-(total*0.10);
	       }System.out.println(total);
	   }

	}
}
